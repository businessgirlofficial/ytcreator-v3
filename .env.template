# YTCreator Studio v3 — Configuracion unificada
# Copia como .env y llena tus valores reales

# ============================================================
# OBLIGATORIAS (el pipeline no funciona sin estas)
# ============================================================

# Groq — LLM para todos los agentes de texto (gratis en console.groq.com)
GROQ_API_KEY=gsk_...

# Kaggle — para generacion visual con GPU (kaggle.com/settings → API)
KAGGLE_USERNAME=samuelcalambas
KAGGLE_KEY=KGAT_...

# ============================================================
# OPCIONALES — el pipeline funciona sin estas (degrada con gracia)
# ============================================================

# Groq: modelo alternativo (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Kaggle: slugs de tu dataset/notebook (default: samuelcalambas/ytcreator-prompts)
# KAGGLE_DATASET_SLUG=samuelcalambas/ytcreator-prompts
# KAGGLE_KERNEL_SLUG=samuelcalambas/youtube-ai-studio-v7-hibrido

# Pixabay — musica de fondo gratis (pixabay.com/api/docs/)
PIXABAY_API_KEY=

# Suno — musica IA (requiere proveedor tercero, no es gratis)
# SUNO_API_KEY=
# SUNO_API_BASE_URL=

# YouTube — para publicacion directa (futuro)
# YOUTUBE_API_KEY=

# Whisper — tamano del modelo de subtitulos (tiny/base/small/medium)
# WHISPER_MODEL_SIZE=base

# Video — resolucion y FPS de salida
# RESOLUCION_VIDEO=1920x1080
# FPS_VIDEO=30

# Subtitulos — ruta a fuente .ttf para quemar en video
# Windows: C:\Windows\Fonts\arialbd.ttf
# Docker:  /usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf
SUBTITULOS_FONT_PATH=

# Storage — directorio base para archivos persistentes (default: directorio actual)
# En Docker/HF Spaces usa /data
# STORAGE_DIR=
