# YTCreator Studio v3 — Configuracion unificada
# Copia como .env y llena tus valores reales

# ============================================================
# SEGURIDAD — protege el gateway de accesos no autorizados
# ============================================================

# API key para autenticar llamadas al gateway (genera una con: python -c "import secrets; print(secrets.token_urlsafe(32))")
YTCREATOR_API_KEY=

# ============================================================
# OBLIGATORIAS (el pipeline no funciona sin estas)
# ============================================================

# Groq — LLM para todos los agentes de texto (gratis en console.groq.com)
GROQ_API_KEY=gsk_...

# Kaggle — para generacion visual con GPU (kaggle.com/settings → API)
KAGGLE_USERNAME=samuelcalambas
KAGGLE_KEY=KGAT_...

# Modal — generacion visual GPU serverless (modal.com/settings)
# Solo necesario en Computador 2 (canales impares)
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...

# Beam Cloud — generacion visual GPU serverless (beam.cloud/settings)
# Solo necesario en Computador 2 (canales pares)
# BEAM_API_KEY=...

# ============================================================
# OPCIONALES — el pipeline funciona sin estas (degrada con gracia)
# ============================================================

# Groq: modelo alternativo (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Claude Code SDK — usa tu suscripcion Pro (no necesita API key)
# Prerequisito: npm install -g @anthropic-ai/claude-code && claude login
# CLAUDE_RATE_LIMIT=10
# CLAUDE_MAX_TURNS=1
# CLAUDE_MODEL=claude-sonnet-4-6

# Kaggle: slugs de tu dataset/notebook (default: samuelcalambas/ytcreator-prompts)
# KAGGLE_DATASET_SLUG=samuelcalambas/ytcreator-prompts
# KAGGLE_KERNEL_SLUG=samuelcalambas/youtube-ai-studio-v7-hibrido

# Hugging Face — musica IA con MusicGen (gratis en huggingface.co/settings/tokens)
HF_API_TOKEN=hf_...

# Pixabay — fallback de musica si MusicGen falla (pixabay.com/api/docs/)
# PIXABAY_API_KEY=

# YouTube — para publicacion automatica (corre scripts/youtube_auth.py una vez para obtener el refresh token)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=

# YouTube Data API — para Channel Intelligence (lectura de datos publicos de canales/competidores)
# Obtener en: console.cloud.google.com → Credentials → Create API Key
# YOUTUBE_API_KEY=AIza...

# Channel Intelligence — TTL en horas para cache de datos de canal (default: 24)
# CANAL_CACHE_TTL_HORAS=24

# Channel Intelligence — limite diario de quota YouTube Data API (default: 9000, dejando 1000 de buffer)
# YOUTUBE_QUOTA_LIMITE=9000

# Whisper — tamano del modelo de subtitulos (tiny/base/small/medium)
# WHISPER_MODEL_SIZE=base

# Video — resolucion y FPS de salida
# RESOLUCION_VIDEO=1920x1080
# FPS_VIDEO=30

# Subtitulos — ruta a fuente .ttf para quemar en video
# Windows: C:\Windows\Fonts\arialbd.ttf
# Docker:  /usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf
SUBTITULOS_FONT_PATH=

# Subtitulos — palabras por bloque (3 para Shorts, 6-8 para long-form)
# SUBTITULOS_PALABRAS_POR_BLOQUE=3

# Scheduling — cuantos videos completados sin publicar se permiten antes de pausar generacion
# BUFFER_MAX_VIDEOS=3

# Storage — directorio base para archivos persistentes (default: directorio actual)
# En Docker/HF Spaces usa /data
# STORAGE_DIR=
